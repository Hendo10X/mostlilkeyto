# Neon Postgres connection string (https://neon.tech)
# e.g. postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# better-auth secret — generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL of the app (used by better-auth for callbacks / cookies)
BETTER_AUTH_URL=http://localhost:3000
